{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/login", "destination": "/client/login.html" },
    { "source": "/register", "destination": "/client/register.html" },
    { "source": "/dashboard", "destination": "/client/dashboard.html" },
    { "source": "/careers", "destination": "/client/careers.html" },
    { "source": "/team", "destination": "/client/team.html" },
    { "source": "/((?!api/).*)", "destination": "/client/$1" }
  ]
}
